{
  "tailwindCSS.experimental.configFile": {
    "assets/css/tailwind-src.css": "{**/*.php,**/*.js,**/*.ts,**/*.jsx,**/*.tsx}"
  },
  "tailwindCSS.includeLanguages": {
    "php": "html"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "[php]": {
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "off",
      "strings": "on"
    }
  }
}
